# Cloudflare Pages – cache-styring
# CSS og JS skal alltid revalideres, så oppdateringer vises uten manuell cache-busting.
/styles.css
  Cache-Control: public, max-age=0, must-revalidate
/app.js
  Cache-Control: public, max-age=0, must-revalidate
# PWA-/admin-sider: alltid revalider HTML, så app-endringer vises uten privat fane.
/app/*
  Cache-Control: public, max-age=0, must-revalidate
/admin/*
  Cache-Control: public, max-age=0, must-revalidate
